#! /bin/csh -f
# Script to make HMI lev1.5 observables from HMI lev1 data
#

# XXXXXXXXXX test
# set echo
# XXXXXXXXXX test
set HERE = $cwd

if ( ! $?WORKFLOW_DATA ) then
    echo WORKFLOW_DATA environment variable is undefined
    exit 1
endif

set WORKFLOW_DIR = "${DRMS_SRC_INSTALL_DIR}"/workflow
set ECLIPSE = $WORKFLOW_DIR/scripts/eclipse.pl
set MAKE_TICKET = $WORKFLOW_DIR/maketicket.csh
set INDEX_CONVERT = "${DRMS_BINS_INSTALL_DIR}"/index_convert
set OBSERVABLES = "${DRMS_BINS_INSTALL_DIR}"/HMI_observables

set QSUBFLAGS = "-v JSOC_r10"
if ( $?WORKFLOW_TEST ) then
    set QUE = k.q
    @ THREADS = 4
    set QSUB = "/SGE2/bin/lx-amd64/qsub $QSUBFLAGS -pe smp $THREADS"
else
    if ( $JSOC_MACHINE == "linux_x86_64" ) then
      set QUE = j.q
      @ THREADS = 1
      set QSUB = "qsub $QSUBFLAGS"
    else if ( $JSOC_MACHINE == "linux_avx" ) then
      set QUE = p4.q
      @ THREADS = 4
	set QSUB = "/SGE2/bin/lx-amd64/qsub $QSUBFLAGS"
    endif
endif

foreach ATTR (WANTLOW WANTHIGH GATE)
   set ATTRTXT = `grep $ATTR ticket`
   set $ATTRTXT
end

set product = `cat $WORKFLOW_DATA/gates/$GATE/product`
set key = `cat $WORKFLOW_DATA/gates/$GATE/key`

# note in Sebastien's code camera=1 is front camera, where CAMERA=2.
set camera = 1
set nrt = 0
set cadence = 45
set input = hmi.lev1

if ( $?WORKFLOW_TEST ) then
    set test_flag = "-t"
else
    set test_flag = ""
endif

## CHANGED on 10/16/2012 for Sebastien's new observables code
set otherargs = "levin="lev1" levout="lev15" wavelength=3 smooth=1 linearity=1 "

# round times to a slot
set indexlow = `$INDEX_CONVERT ds=$product $key=$WANTLOW`
set indexhigh = `$INDEX_CONVERT ds=$product $key=$WANTHIGH`
@ indexhigh = $indexhigh - 1
set wantlow = `$INDEX_CONVERT ds=$product $key"_index"=$indexlow`
set wanthigh = `$INDEX_CONVERT ds=$product $key"_index"=$indexhigh`
# make qsub name from index from door opening
# set indexbase = `$INDEX_CONVERT ds=$product $key=2010.03.24_TAI`
# @ qsubname = $indexhigh - $indexbase
set timestr = `echo $wantlow  | sed -e 's/[.:]//g' -e 's/^......//' -e 's/.._TAI//'`
set timename = OBS
set qsubname = $timename$timestr

if ($indexhigh < $indexlow) then
   echo No data to process, $WANTLOW to $WANTHIGH > $HERE/runlog
   exit 0
endif

set TEMPLOG = $HERE/runlog
set babble = $HERE/babble
set TEMPCMD = $HERE/$qsubname
echo 6 > $HERE/retstatus

# check for eclipse quality bits to be set in lev1_nrt
#$ECLIPSE $wantlow $wanthigh


set retstatus=0
# make qsub script
echo "#! /bin/csh -f " >$TEMPCMD
echo "setenv OMP_NUM_THREADS $THREADS" >>$TEMPCMD
echo "cd $HERE" >>$TEMPCMD
echo "hostname >>&$TEMPLOG" >>$TEMPCMD
echo "$OBSERVABLES -L $test_flag lev1=$input quicklook=$nrt camid=$camera cadence=$cadence $otherargs begin="$wantlow"  end="$wanthigh"  >>&$TEMPLOG" >>$TEMPCMD
echo 'set retstatus = $?' >>$TEMPCMD
echo 'echo $retstatus >' "$HERE/retstatus" >>$TEMPCMD
echo "rm -f $HERE/qsub_running" >>$TEMPCMD

# execute qsub script
touch $HERE/qsub_running
set TEMPLOG = `echo $TEMPLOG | sed "s/^\/auto//"`
$QSUB -sync yes -e $TEMPLOG -o $TEMPLOG -q $QUE $TEMPCMD >> runlog

# set waitcount=0
# while (-e $HERE/qsub_running)
    # sleep 10
    # @ waitcount = $waitcount + 1
    # if ($waitcount > 720) then
      # echo "timed out after 2 hours" >$HERE/FailMessage
      # set retstatus = 5
      # exit $retstatus
    # endif
    # echo -n '+' >>$babble
# end

if (-e retstatus) set retstatus = `cat $HERE/retstatus`
if ($retstatus == 0 ) then
  set WEBIMAGE_TICKET = `$MAKE_TICKET gate=hmi.defImages wantlow=$wantlow wanthigh=$wanthigh action=5`
  set VW_TICKET = `$MAKE_TICKET gate=hmi.vw_V wantlow=$wantlow wanthigh=$wanthigh action=5`
endif

exit $retstatus
